   "source": [
    "def search(matrix,x):\n",
    "    m=len(matrix)\n",
    "    n=len(matrix[0])\n",
    "\n",
    "    i=0\n",
    "    j=m*n-1\n",
    "\n",
    "    while i<=j:\n",
    "        mid=i+(j-i)//2\n",
    "        midEle=matrix[mid//m][mid%n]\n",
    "\n",
    "        if midEle==x:\n",
    "            return "
   ]
