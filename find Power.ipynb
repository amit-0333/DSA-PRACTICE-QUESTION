    "def findPower(a,n):\n",
    "    if n==0:\n",
    "        return 0\n",
    "    elif n==1:\n",
    "        return a\n",
    "    else:\n",
    "        mid=n//2\n",
    "        res=findPower(a,mid)\n",
    "    if n%2==0:\n",
    "        return res*res\n",
    "    else:\n",
    "        return res*res*a\n",
    "\n",
    "a=2\n",
    "n=7\n",
    "print(findPower(\n"
